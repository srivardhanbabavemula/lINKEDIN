# LinkedIn credentials (LOCAL ONLY — never commit)
LINKEDIN_EMAIL=your-email@example.com
LINKEDIN_PASSWORD=your-password

# LLM provider: ollama | lmstudio
LLM_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
LMSTUDIO_HOST=http://localhost:1234
LMSTUDIO_MODEL=local-model

# Your profile — edit these
MY_NAME=Your Name
MY_SCHOOL=University at Buffalo
MY_DEGREE=MS in Data Science
MY_TARGET_ROLE=internships, co-op, and full-time opportunities
MY_LOCATION=Buffalo

# Optional: narrow scoring focus (leave blank for any internship)
# Examples: technology, finance, consulting
MY_INTERNSHIP_FIELD=

# Scoring
MIN_CONTACT_SCORE=50
MESSAGES_PER_SESSION=30
WEEKLY_MESSAGE_LIMIT=30

# Safety limits
MAX_SCRAPE_PER_SESSION=15
MAX_SCRAPE_PER_DAY=25
SCRAPE_DELAY_SECONDS=3.0

DATABASE_PATH=database/linkedin.db
